@{
    ViewData["Title"] = "Регистрация";
}

<style>

*{box-sizing:border-box}
body{
  margin:0;
  min-height:100vh;
  display:flex;
  justify-content:center;
  align-items:center;
  background:linear-gradient(135deg,#3d8b6e,#f6b483);
  font-family:'Archivo',sans-serif;
}

.card{
  background:#fff;
  padding:3.5rem 3rem;
  border-radius:2.5rem;
  max-width:440px;
  width:100%;
  text-align:center;
  box-shadow:0 25px 50px rgba(0,0,0,.2);
}

h1{
  font-family:'Clash Display',sans-serif;
  font-size:2.6rem;
  margin-bottom:.5rem;
  color:#2b5e4b;
}

p{color:#9c6a46;margin-bottom:2rem}

input{
  width:100%;
  padding:1rem 1.2rem;
  border-radius:1rem;
  border:1px solid #f0c8a8;
  margin-bottom:1.1rem;
  font-size:1rem;
}

button{
  width:100%;
  padding:1rem;
  border:none;
  border-radius:2rem;
  background:#286b53;
  color:#fff;
  font-size:1.1rem;
  font-weight:600;
  cursor:pointer;
  box-shadow:0 15px 25px rgba(40,107,83,.35);
}

a{
  display:inline-block;
  margin-top:1.5rem;
  color:#2b5e4b;
  text-decoration:none;
  font-weight:600;
}
</style>

<form method="post" action="/Auth/Register">
    <div class="card">
        <h1>Регистрация</h1>
        <p>Создай аккаунт и начни приключение</p>

        <input type="text" name="name" placeholder="Имя" required>
        <input type="email" name="email" placeholder="Email" required>
        <input type="password" name="password" placeholder="Пароль" required>
        <input type="password" name="confirmPassword" placeholder="Повтори пароль" required>

        <button type="submit">Создать аккаунт</button>

        <a href="/Auth/Login">Уже есть аккаунт? Войти</a>
    </div>
</form>
