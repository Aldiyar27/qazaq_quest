@{
    ViewData["Title"] = "Ошибка";
}

<section class="container section-space">
    <div class="panel">
        <div class="eyebrow">Системное сообщение</div>
        <h1>Что-то пошло не так</h1>
        <p class="muted">Во время обработки запроса возникла ошибка. Вернись на главную страницу и попробуй снова.</p>
        <div class="card-actions spaced">
            <a class="btn btn-primary" asp-controller="Home" asp-action="Index">На главную</a>
            <a class="btn btn-ghost" asp-controller="Quest" asp-action="Index">Каталог квестов</a>
        </div>
    </div>
</section>
